# Email to receive new lead notifications
NOTIFICATION_EMAIL=admin@theforwardhorizon.com

# Google Analytics
NEXT_PUBLIC_GA_ID=GA_MEASUREMENT_ID

# Facebook Pixel
NEXT_PUBLIC_FB_PIXEL_ID=FB_PIXEL_ID